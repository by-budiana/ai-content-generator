// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi
  contents Content[]
  ratings  Rating[]

  @@index([email])
}

model Content {
  id          Int      @id @default(autoincrement())
  userId      Int
  inputPrompt String
  result      String
  type        String // Emulated Enum ContentType: "CAPTION", "DESCRIPTION", "TAGLINE"
  language    String // Emulated Enum Language: "ID", "EN"
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relasi
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ratings Rating[]

  @@index([userId])
  @@index([type])
  @@index([isFavorite])
}

model Template {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  type        String // Emulated Enum ContentType: "CAPTION", "DESCRIPTION", "TAGLINE"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt // Tambahan best practice untuk template

  @@index([type])
}

model Rating {
  id        Int      @id @default(autoincrement())
  userId    Int
  contentId Int
  value     Int // Ubah dari String ke Int untuk mendukung angka 1-5
  createdAt DateTime @default(now())

  // Relasi tetap sama
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([userId])
  @@index([contentId])
}
